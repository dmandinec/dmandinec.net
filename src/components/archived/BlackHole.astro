<div id="blackhole-container"></div>

<script>
  import * as THREE from 'three';

  const scene = new THREE.Scene();
  const camera = new THREE.OrthographicCamera(-1, 1, 1, -1, 0, 1);
  const renderer = new THREE.WebGLRenderer({ antialias: true });
  
  renderer.setSize(window.innerWidth, window.innerHeight);
  const container = document.getElementById('blackhole-container');
  if (container) container.appendChild(renderer.domElement);

  const geometry = new THREE.PlaneGeometry(2, 2);
  const material = new THREE.ShaderMaterial({
    uniforms: {
      uTime: { value: 0 },
      uResolution: { value: new THREE.Vector2(window.innerWidth, window.innerHeight) },
    },
    vertexShader: `
      varying vec2 vUv;
      void main() {
        vUv = uv;
        gl_Position = vec4(position, 1.0);
      }
    `,
    fragmentShader: `
      varying vec2 vUv;
      uniform float uTime;
      uniform vec2 uResolution;

      float hash(vec2 p) {
        return fract(sin(dot(p, vec2(12.71, 31.17))) * 43758.5453);
      }

      float noise(vec2 p) {
        vec2 i = floor(p);
        vec2 f = fract(p);
        vec2 u = f * f * (3.0 - 2.0 * f);
        return mix(
          mix(hash(i + vec2(0.0, 0.0)), hash(i + vec2(1.0, 0.0)), u.x),
          mix(hash(i + vec2(0.0, 1.0)), hash(i + vec2(1.0, 1.0)), u.x),
          u.y
        );
      }

      float fbm(vec2 p) {
        float value = 0.0;
        float amplitude = 0.5;
        for (int i = 0; i < 4; i++) {
          value += amplitude * noise(p);
          p *= 2.0;
          amplitude *= 0.5;
        }
        return value;
      }

      void main() {
        vec2 uv = (gl_FragCoord.xy - 0.5 * uResolution.xy) / min(uResolution.y, uResolution.x);
        float r = length(uv);
        float angle = atan(uv.y, uv.x);

        // Gravitational lensing
        float lensStrength = 0.04 / (r + 0.02);
        vec2 lensUv = uv * (1.0 + lensStrength);
        float lensR = length(lensUv);
        float lensAngle = atan(lensUv.y, lensUv.x) + lensStrength * 2.0;

        // Event horizon
        float eventHorizon = smoothstep(0.12, 0.14, lensR);

        // Photon ring (bright ring around black hole)
        float photonRing = exp(-pow((lensR - 0.15) * 30.0, 2.0));

        // Accretion disk
        float diskRadius = smoothstep(0.8, 0.15, lensR);
        float diskAngle = lensAngle + uTime * 0.3;
        float spiral = sin(diskAngle * 3.0 + lensR * 20.0 - uTime * 2.0) * 0.5 + 0.5;
        float turbulence = fbm(vec2(lensR * 8.0 - uTime * 0.5, diskAngle * 2.0));
        float disk = diskRadius * (spiral * 0.6 + turbulence * 0.4);

        // Disk color gradient
        vec3 innerColor = vec3(1.0, 0.85, 0.5);
        vec3 midColor = vec3(1.0, 0.4, 0.1);
        vec3 outerColor = vec3(0.6, 0.1, 0.05);
        float colorMix = smoothstep(0.15, 0.5, lensR);
        vec3 diskColor = mix(innerColor, midColor, colorMix);
        diskColor = mix(diskColor, outerColor, smoothstep(0.3, 0.7, lensR));

        // Doppler beaming (one side brighter)
        float doppler = 0.7 + 0.3 * sin(lensAngle - uTime * 0.5);
        disk *= doppler;

        // Glow
        float glow = 0.02 / (lensR + 0.05);
        vec3 glowColor = vec3(0.8, 0.4, 0.2) * glow;

        // Background stars (subtle)
        float stars = step(0.998, hash(floor(uv * 300.0)));
        stars *= smoothstep(0.2, 0.5, r);

        // Compose
        vec3 color = vec3(0.0);
        color += diskColor * disk * 1.5;
        color += innerColor * photonRing * 0.8;
        color += glowColor;
        color += vec3(stars) * 0.5;
        color *= eventHorizon;

        // Tone mapping
        color = color / (color + 0.5);

        gl_FragColor = vec4(color, 1.0);
      }
    `
  });

  const mesh = new THREE.Mesh(geometry, material);
  scene.add(mesh);

  function animate() {
    requestAnimationFrame(animate);
    material.uniforms.uTime.value += 0.016;
    renderer.render(scene, camera);
  }

  window.addEventListener('resize', () => {
    renderer.setSize(window.innerWidth, window.innerHeight);
    material.uniforms.uResolution.value.set(window.innerWidth, window.innerHeight);
  });

  animate();
</script>

<style>
  #blackhole-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: -1;
    background: #000;
  }
</style>
