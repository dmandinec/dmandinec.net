<div id="orbiting-planets-container"></div>

<script>
  import * as THREE from 'three';

  const scene = new THREE.Scene();
  const camera = new THREE.PerspectiveCamera(50, window.innerWidth / window.innerHeight, 0.1, 1000);
  camera.position.set(0, 8, 15);
  camera.lookAt(0, 0, 0);

  const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
  renderer.setSize(window.innerWidth, window.innerHeight);
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
  
  const container = document.getElementById('orbiting-planets-container');
  if (container) container.appendChild(renderer.domElement);

  // Star texture
  const canvas = document.createElement('canvas');
  canvas.width = 64;
  canvas.height = 64;
  const ctx = canvas.getContext('2d');
  const gradient = ctx.createRadialGradient(32, 32, 0, 32, 32, 32);
  gradient.addColorStop(0, 'rgba(255, 255, 255, 1)');
  gradient.addColorStop(0.3, 'rgba(255, 200, 100, 0.6)');
  gradient.addColorStop(1, 'rgba(0, 0, 0, 0)');
  ctx.fillStyle = gradient;
  ctx.fillRect(0, 0, 64, 64);
  const glowTexture = new THREE.CanvasTexture(canvas);

  // Sun with corona layers
  const sunGroup = new THREE.Group();
  const sunCore = new THREE.Mesh(
    new THREE.SphereGeometry(1, 32, 32),
    new THREE.MeshBasicMaterial({ color: 0xffdd44 })
  );
  sunGroup.add(sunCore);

  for (let i = 1; i <= 3; i++) {
    const corona = new THREE.Mesh(
      new THREE.SphereGeometry(1 + i * 0.4, 32, 32),
      new THREE.MeshBasicMaterial({
        color: i === 1 ? 0xffaa00 : i === 2 ? 0xff6600 : 0xff3300,
        transparent: true,
        opacity: 0.15 / i,
      })
    );
    sunGroup.add(corona);
  }
  scene.add(sunGroup);

  // Planets with better materials
  const planets = [];
  const planetData = [
    { radius: 0.2, distance: 2.5, speed: 0.015, color: 0xaaaaaa, tilt: 0.1, ring: false },
    { radius: 0.35, distance: 3.8, speed: 0.01, color: 0xe87d4f, tilt: 0.15, ring: false },
    { radius: 0.4, distance: 5.2, speed: 0.007, color: 0x4a90d9, tilt: -0.1, ring: false },
    { radius: 0.25, distance: 6.8, speed: 0.005, color: 0xd45d7a, tilt: 0.2, ring: false },
    { radius: 0.6, distance: 8.5, speed: 0.003, color: 0xf0c040, tilt: -0.15, ring: true },
  ];

  planetData.forEach(data => {
    const geometry = new THREE.SphereGeometry(data.radius, 32, 32);
    const material = new THREE.MeshStandardMaterial({
      color: data.color,
      roughness: 0.6,
      metalness: 0.2,
    });
    const planet = new THREE.Mesh(geometry, material);
    planet.userData = { distance: data.distance, speed: data.speed, angle: Math.random() * Math.PI * 2, tilt: data.tilt };
    scene.add(planet);
    planets.push(planet);

    // Saturn-like ring for the largest planet
    if (data.ring) {
      const ringGeo = new THREE.RingGeometry(data.radius * 1.4, data.radius * 2.2, 64);
      const ringMat = new THREE.MeshBasicMaterial({
        color: 0xddcc88,
        transparent: true,
        opacity: 0.5,
        side: THREE.DoubleSide,
      });
      const ring = new THREE.Mesh(ringGeo, ringMat);
      ring.rotation.x = Math.PI / 2.5;
      planet.add(ring);
    }

    // Orbit path
    const orbitGeo = new THREE.BufferGeometry();
    const orbitPoints = [];
    for (let i = 0; i <= 128; i++) {
      const a = (i / 128) * Math.PI * 2;
      orbitPoints.push(Math.cos(a) * data.distance, 0, Math.sin(a) * data.distance);
    }
    orbitGeo.setAttribute('position', new THREE.Float32BufferAttribute(orbitPoints, 3));
    const orbitMat = new THREE.LineBasicMaterial({ color: 0xffffff, transparent: true, opacity: 0.08 });
    const orbitLine = new THREE.Line(orbitGeo, orbitMat);
    scene.add(orbitLine);
  });

  // Lighting
  scene.add(new THREE.AmbientLight(0x222233, 0.5));
  const sunLight = new THREE.PointLight(0xffaa44, 3, 50);
  sunLight.position.set(0, 0, 0);
  scene.add(sunLight);

  // Background stars with texture
  const starCount = 3000;
  const starPos = new Float32Array(starCount * 3);
  const starSizes = new Float32Array(starCount);
  for (let i = 0; i < starCount; i++) {
    starPos[i * 3] = (Math.random() - 0.5) * 200;
    starPos[i * 3 + 1] = (Math.random() - 0.5) * 200;
    starPos[i * 3 + 2] = (Math.random() - 0.5) * 200;
    starSizes[i] = Math.random() * 0.3 + 0.1;
  }
  const starGeo = new THREE.BufferGeometry();
  starGeo.setAttribute('position', new THREE.BufferAttribute(starPos, 3));
  starGeo.setAttribute('size', new THREE.BufferAttribute(starSizes, 1));
  const starMat = new THREE.PointsMaterial({
    size: 0.2,
    map: glowTexture,
    color: 0xffffff,
    transparent: true,
    opacity: 0.8,
    blending: THREE.AdditiveBlending,
    depthWrite: false,
  });
  const bgStars = new THREE.Points(starGeo, starMat);
  scene.add(bgStars);

  function animate() {
    requestAnimationFrame(animate);

    sunCore.rotation.y += 0.003;
    sunGroup.children.forEach((child, i) => {
      if (i > 0) child.scale.setScalar(1 + Math.sin(Date.now() * 0.001 + i) * 0.05);
    });

    planets.forEach(planet => {
      planet.userData.angle += planet.userData.speed;
      planet.position.x = Math.cos(planet.userData.angle) * planet.userData.distance;
      planet.position.z = Math.sin(planet.userData.angle) * planet.userData.distance;
      planet.position.y = Math.sin(planet.userData.angle) * planet.userData.tilt;
      planet.rotation.y += 0.01;
    });

    bgStars.rotation.y += 0.00005;

    renderer.render(scene, camera);
  }

  window.addEventListener('resize', () => {
    camera.aspect = window.innerWidth / window.innerHeight;
    camera.updateProjectionMatrix();
    renderer.setSize(window.innerWidth, window.innerHeight);
  });

  animate();
</script>

<style>
  #orbiting-planets-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: -1;
    background: radial-gradient(circle at center, #0a0a2e 0%, #000000 100%);
  }
</style>
